# Copie para .env e ajuste os valores

# -----------------------------------------------------------------
# Banco de Dados (PostgreSQL)
# Local: instância local. Railway: use a variável do plugin Postgres.
# Atenção: caracteres especiais na senha precisam ser URL-encoded (@ -> %40).
# -----------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/adcesp?schema=public"

# -----------------------------------------------------------------
# NextAuth.js — gere o segredo com: openssl rand -base64 32
# NEXTAUTH_URL deve ser a URL pública da aplicação em produção.
# -----------------------------------------------------------------
NEXTAUTH_SECRET="gere-com-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------
# App
# -----------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="ADCESP - Secção Sindical dos Docentes da UESPI"

# -----------------------------------------------------------------
# Armazenamento de arquivos (uploads)
# Os arquivos NÃO ficam em `public/` — são gravados neste diretório e
# servidos pela rota /api/files/[...path].
#
#   Local   : ./private/storage
#   Railway : aponte para o mount path do Volume (ex.: /data)
# -----------------------------------------------------------------
STORAGE_PATH="./private/storage"

# -----------------------------------------------------------------
# Usuário administrador criado pelo seed (npm run db:seed).
# Obrigatórios: o seed falha se não estiverem definidos.
# -----------------------------------------------------------------
ADMIN_EMAIL="adcesp@gmail.com"
ADMIN_PASSWORD="defina-uma-senha-forte"
